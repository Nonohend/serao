# ---------------------------------------------------------------------------
# Mon Coloc IA — Variables d'environnement
# Copier ce fichier vers .env.local puis renseigner vos propres valeurs.
# ---------------------------------------------------------------------------

# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY

# Clé de service Supabase (côté serveur uniquement — jamais exposée au client).
# Utilisée par le cron pour lire les dépenses de tous les utilisateurs.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Anthropic (Claude) — utilisé par le Vercel AI SDK
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# Tavily — recherche web pour l'outil "rechercheWeb"
# https://app.tavily.com
TAVILY_API_KEY=tvly-YOUR_KEY

# Secret partagé protégeant la route cron (Vercel envoie ce Bearer).
CRON_SECRET=change-me-with-a-long-random-string

# Webhook optionnel pour l'envoi du bilan flash quotidien (Slack, Discord, etc.)
DAILY_REPORT_WEBHOOK_URL=
